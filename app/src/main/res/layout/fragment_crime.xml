<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/crime_photo"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:adjustViewBounds="true"
                    android:background="#BEBEBE"
                    android:contentDescription="@string/crime_photo"
                    android:padding="0dp"
                    android:scaleType="centerCrop"
                    tools:srcCompat="@drawable/ic_solved" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/crime_camera"
                    android:layout_width="36dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"
                    android:contentDescription="@string/take_photo"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:text=""
                    app:backgroundTint="#EEEEEE"
                    app:cornerRadius="0dp"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="#666666"
                    app:rippleColor="#D0D0D0"
                    app:strokeColor="#C9C9C9"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/crime_title_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/crime_title_label"
                    android:textColor="#6E6E6E"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/crime_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:backgroundTint="#F05A91"
                    android:hint="@string/crime_title_hint"
                    android:paddingBottom="6dp"
                    android:singleLine="true"
                    android:textColor="#222222"
                    android:textColorHint="#8A8A8A"
                    android:textSize="16sp"
                    tools:text="Yogurt thievery" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crime_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:enabled="false"
            android:gravity="start|center_vertical"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="48dp"
            android:textAllCaps="false"
            android:textColor="#222222"
            app:backgroundTint="@android:color/white"
            app:cornerRadius="0dp"
            app:strokeColor="#D3D3D3"
            app:strokeWidth="1dp"
            tools:text="Fri Mar 20 2026, 01:16 PM" />

        <CheckBox
            android:id="@+id/crime_solved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/crime_solved_label"
            android:textColor="#222222"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/crime_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Case Closed" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crime_suspect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="44dp"
            android:text="@string/choose_suspect"
            android:textAllCaps="true"
            android:textColor="#3A3A3A"
            android:textSize="12sp"
            app:backgroundTint="#D9D9D9"
            app:cornerRadius="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crime_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="44dp"
            android:text="@string/send_report"
            android:textAllCaps="true"
            android:textColor="#111111"
            android:textSize="12sp"
            app:backgroundTint="#D9D9D9"
            app:cornerRadius="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crime_call_suspect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="44dp"
            android:text="@string/call_suspect_default"
            android:textAllCaps="true"
            android:textColor="#3A3A3A"
            android:textSize="12sp"
            app:backgroundTint="#D9D9D9"
            app:cornerRadius="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crime_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="48dp"
            android:text="@string/save"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            app:cornerRadius="0dp" />

    </LinearLayout>
</ScrollView>
